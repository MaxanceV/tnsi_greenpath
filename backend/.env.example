# Configuration locale du backend GreenPath.
# Copier en `.env` (dans backend/) et remplir.
#
# Le token Hugging Face est requis pour activer le chatbot RAG.
# Comment l'obtenir (gratuit, 1 min) :
#   1. Créer un compte sur https://huggingface.co
#   2. Aller sur https://huggingface.co/settings/tokens
#   3. Créer un token "Read" → coller la valeur ci-dessous

HF_TOKEN=

# Modèle LLM utilisé. Doit être un modèle disponible sur le routeur
# `router.huggingface.co/v1/chat/completions` (nouvelle API HF).
# Quelques alternatives connues comme gratuites :
#   meta-llama/Llama-3.1-8B-Instruct        (défaut, bonne qualité multilingue)
#   Qwen/Qwen2.5-7B-Instruct                (rapide, bon en français)
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
